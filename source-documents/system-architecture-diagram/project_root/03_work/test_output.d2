L4: "Level 4｜企業層  Enterprise Zone" {
  class: zone_l4
  ERP: "ERP 系統" { class: external_system }
  ADCC: "ADCC 電力調度" { class: external_system }
  SCADA_WS: "SCADA 工作站" { class: hmi_workstation }
}

DMZ: "DMZ｜邊界防護  Demilitarized Zone" {
  class: zone_dmz
  FW: "FIREWALL\nEDR-GN010" { class: firewall }
  SW_DMZ: "L3 Switch\nPT-G7728" { class: switch_prp }
  MODEM: "Modem\nPSTN+4G" { class: gateway }
}

L3: "Level 3｜監控站  Supervisory Control Zone" {
  class: zone_l3
  HMI_A: "主站 HMI_A\nDA-820" { class: hmi_workstation }
  HMI_B: "備援 HMI_B\nDA-820" { class: hmi_workstation }
  HIST: "Historian" { class: historian }
  ENG_WS: "Engineering WS\nDHI6C400 / OMCRON" { class: engineering_ws }
  NTP: "NTP Server\nIEEE 1588 PTP" { class: ntp_server }
  GNSS: "GNSS Antenna" { class: ntp_server }
  UPS_L3: "UPS\n10kVA" { class: ups }
}

L2: "Level 2｜控制網路  Control Network Zone" {
  class: zone_l2
  core: "核心交換（雙網 PRP 冗餘）" {
    class: zone_sub
    SW_CORE_A: "Core Switch A" { class: switch_prp }
    SW_CORE_B: "Core Switch B" { class: switch_prp }
  }
  edge: "饋線邊緣交換" {
    class: zone_sub
    SW_M1_A: "SW-M1 LAN-A  161kV TR  MCC 16/17" { class: switch_prp }
    SW_M1_B: "SW-M1 LAN-B" { class: switch_prp }
    SW_M2_A: "SW-M2 LAN-A  161kV BPT / General  MCC 01/02/03" { class: switch_prp }
    SW_M2_B: "SW-M2 LAN-B" { class: switch_prp }
    SW_M3_A: "SW-M3 LAN-A  161kV LINE / TR  MCC 04/05/06" { class: switch_prp }
    SW_M3_B: "SW-M3 LAN-B" { class: switch_prp }
    SW_M4_A: "SW-M4 LAN-A  53.4kV MAIN / BPT  MCC 07/08/09/10" { class: switch_prp }
    SW_M4_B: "SW-M4 LAN-B" { class: switch_prp }
    SW_M5_A: "SW-M5 LAN-A  53.4kV STATCOM  MCC 11/12/13" { class: switch_prp }
    SW_M5_B: "SW-M5 LAN-B" { class: switch_prp }
    SW_M6_A: "SW-M6 LAN-A  23kV  MCC 14/15" { class: switch_prp }
    SW_M6_B: "SW-M6 LAN-B" { class: switch_prp }
  }
}

L1: "Level 1｜現場控制層  Field Control Zone" {
  class: zone_l1
  # T-04: 子群組宣告順序強制為 gw → rtu_panels → mcc → statcom
  gw: "Protocol Gateway" {
    class: zone_sub
    GW_A: "GW_A\nIEC-7442 / Advantech" { class: gateway }
    GW_B: "GW_B\nIEC-7442 / Advantech" { class: gateway }
    # 協定轉換：IEC61850 → Modbus RTU  IEC61850 → RS-485
  }
  tpc: "TPC RTU 盤" {
    class: zone_sub
    RTU_TPC: "RTU\nRSG-007R" { class: rtu_ied }
    REDBOX_TPC: "RedBox" { class: redbox }
    IED_87L1: "87L1\n線路保護" { class: field_ied }
    IED_87L2: "87L2\n線路保護" { class: field_ied }
    IED_60BF: "60BF\n斷路器失效" { class: field_ied }
  }
  mcc: "MCC 群" {
    class: zone_sub
    MCC_M1: "MCC-M1  161kV TR  盤16/17" { class: plc }
    MCC_M2: "MCC-M2  161kV BPT / General  盤01/02/03" { class: plc }
    MCC_M3: "MCC-M3  161kV LINE / TR  盤04/05/06" { class: plc }
    MCC_M4: "MCC-M4  53.4kV MAIN / BPT  盤07/08/09/10" { class: plc }
    MCC_M5: "MCC-M5  53.4kV STATCOM  盤11/12/13" { class: plc }
    MCC_M6: "MCC-M6  23kV  盤14/15" { class: plc }
  }
  statcom: "STATCOM 系統" {
    class: zone_sub
    OSC: "OSC 控制器\nBPX-B1" { class: plc }
    LNK_A: "LNK-A  Modbus TCP" { class: gateway }
    LNK_B: "LNK-B  Modbus TCP" { class: gateway }
    LNK_C: "LNK-C  Modbus TCP" { class: gateway }
  }
}

L0: "Level 0｜現場設備  Field Devices" {
  class: zone_l0
  # R-D2-05: r_group 在前（左），solar 在後（右）
  r_group: "R 群（保護電驛 IED）" {
    class: zone_sub
    IED_87T: "87T1 / 87T2\n變壓器差動保護" { class: field_ied }
    IED_87B: "87B\n匯流排保護" { class: field_ied }
    IED_87L: "87L\n線路差動保護" { class: field_ied }
    IED_50BF: "50BF-1/2\n斷路器失效保護" { class: field_ied }
    IED_50S: "50/51-1/2\n過電流保護" { class: field_ied }
    IED_D7: "87D / 87D2\n其他差動保護" { class: field_ied }
  }
  solar: "太陽能 / 儲能設備" {
    class: zone_sub
    INV_A: "Inverter 群 A\nDC → AC" { class: inverter }
    INV_B: "Inverter 群 B\nDC → AC" { class: inverter }
    DC_CHG: "DC CHARGE\n充放電系統" { class: plc }
    RF_MOD: "RF Solar Module\n無線監測" { class: gateway }
    UPS_FIELD: "UPS（現場）\nSerial RS485" { class: ups }
  }
}

