{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Knowledge Base Index",
  "description": "Schema for index.json produced by large-doc-search ingest.py",
  "type": "object",
  "required": ["kb_name", "source_file", "total_pages", "total_chapters", "created_at", "ingest_version", "chapters"],
  "properties": {
    "kb_name": {
      "type": "string",
      "description": "Knowledge base name (usually derived from PDF filename)"
    },
    "source_file": {
      "type": "string",
      "description": "Original PDF filename"
    },
    "total_pages": {
      "type": "integer",
      "minimum": 1,
      "description": "Total pages in source PDF"
    },
    "total_chapters": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of chapters in the knowledge base"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the knowledge base was created"
    },
    "ingest_version": {
      "type": "string",
      "description": "Version of ingest.py that produced this index"
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "page_range", "file", "char_count", "summary", "keywords", "has_tables", "related_tables"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ch\\d{2}[a-z]?$",
            "description": "Chapter ID, e.g., ch01, ch07a"
          },
          "title": {
            "type": "string",
            "description": "Chapter title as detected from PDF"
          },
          "page_range": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2,
            "description": "Start and end page numbers (1-indexed)"
          },
          "file": {
            "type": "string",
            "description": "Relative path to the chapter Markdown file"
          },
          "char_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Character count of the chapter text"
          },
          "summary": {
            "type": "string",
            "description": "Extractive summary of the chapter (~100-150 chars)"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Extracted keywords for matching"
          },
          "has_tables": {
            "type": "boolean",
            "description": "Whether tables were extracted from this chapter"
          },
          "related_tables": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Paths to extracted table files"
          },
          "parent_chapter": {
            "type": "string",
            "description": "If this is a sub-chapter split from an oversized chapter, the parent title"
          }
        }
      }
    }
  }
}
